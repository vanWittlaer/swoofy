# Copy to `secrets.auto.tfvars` (git-ignored) and fill in real values.
# `*.auto.tfvars` is loaded automatically by tofu — no -var-file needed.
#
# coolify_endpoint / coolify_token may also be supplied via the
# COOLIFY_ENDPOINT / COOLIFY_TOKEN env vars instead.

# coolify_endpoint = "https://coolify.example.com"
# coolify_token    = "REPLACE_ME"
#
# The per-environment Coolify SERVER is set inside each secrets_* object below
# (secrets_production.server_uuid / secrets_staging.server_uuid) — the same UUID for both
# co-locates prod and staging; different UUIDs split them across servers. One Coolify
# instance (endpoint/token above) manages both.

# The three values we own (Coolify can't generate them). Generate each with
# `openssl rand -hex 16`; use DISTINCT values for production and staging.
#   - app_secret / instance_id: keep STABLE across deploys (rotating app_secret
#     invalidates live sessions/signed URLs; instance_id identifies the instance).
#   - rabbitmq_password: we run RabbitMQ from our own compose with this password,
#     so the AMQP DSN is derived — no post-deploy UI capture needed.
# DB/Redis passwords stay Coolify-generated (consumed via computed internal_db_url).
# s3_access_key_id / s3_secret_access_key: object-storage credentials for the
# private/public filesystems (from your S3 provider). Buckets are set in
# production.tfvars / staging.tfvars; environments may SHARE buckets (isolated by the
# auto "<env>/" prefix) or use dedicated buckets (set s3.path_prefix = "").
# s3_backup_access_key_id / s3_backup_secret_access_key: required when enable_backup =
# true (set per-env in production.tfvars / staging.tfvars); credentials for the
# (separate-location) backup bucket, from your object-storage provider.
secrets_production = {
  server_uuid                 = "REPLACE_ME" # Coolify server for production
  app_secret                  = "REPLACE_ME"
  instance_id                 = "REPLACE_ME"
  rabbitmq_password           = "REPLACE_ME"
  s3_access_key_id            = "REPLACE_ME"
  s3_secret_access_key        = "REPLACE_ME"
  s3_backup_access_key_id     = "REPLACE_ME" # backup-bucket credentials (required when enable_backup = true)
  s3_backup_secret_access_key = "REPLACE_ME"
  mailer_dsn                  = "null://null" # optional; real SMTP DSN for production mail
}

secrets_staging = {
  server_uuid                 = "REPLACE_ME" # Coolify server for staging (same or different vs prod)
  app_secret                  = "REPLACE_ME"
  instance_id                 = "REPLACE_ME"
  rabbitmq_password           = "REPLACE_ME"
  s3_access_key_id            = "REPLACE_ME"
  s3_secret_access_key        = "REPLACE_ME"
  s3_backup_access_key_id     = "REPLACE_ME" # backup-bucket credentials (required when enable_backup = true)
  s3_backup_secret_access_key = "REPLACE_ME"
  # Mailpit web-UI basic auth (MP_UI_AUTH) when enable_mailpit = true. Space-separated
  # "user:password" pair(s), e.g. "staging:s3cr3t". Empty/omitted => Mailpit UI is open.
  mailpit_ui_auth = "REPLACE_ME"
}
